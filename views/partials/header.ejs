<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory Management | Sneaker Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Reset & Modern Font */
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: #f8fafc;
      color: #1e293b;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background-color: #0f172a; /* Dark Slate Blue */
      color: white;
      padding: 0.75rem 2rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1.25rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: #38bdf8; /* Accent Color */
      text-decoration: none;
    }

    nav {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    nav a {
      color: #cbd5e1;
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 500;
      transition: all 0.2s;
    }

    nav a:hover {
      color: white;
    }

    /* Active State (Visual tip) */
    nav a.active {
      color: white;
      border-bottom: 2px solid #38bdf8;
    }

    .user-section {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .user-greeting {
      font-size: 0.9rem;
      color: #94a3b8;
    }

    .user-name {
      color: white;
      font-weight: 600;
      margin-left: 4px;
    }

    .logout-btn {
      background-color: rgba(239, 68, 68, 0.1);
      color: #f87171;
      border: 1px solid #f87171;
      padding: 6px 14px;
      cursor: pointer;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      transition: all 0.2s;
    }

    .logout-btn:hover {
      background-color: #ef4444;
      color: white;
    }

    main {
      min-height: 80vh;
      padding-top: 20px;
    }
  </style>
</head>
<body>
  <header>
    <a href="<%= locals.user ? '/dashboard' : '/' %>" class="brand">
      <span>👟</span> SNKR_INV
    </a>

    <nav>
      <% if (!locals.user) { %>
        <a href="/">Home</a>
      <% } else { %>
        <a href="/dashboard">Dashboard</a>
      <% } %>
      
      <a href="/reports">Laporan</a>
    </nav>

    <div class="user-section">
      <% if (locals.user) { %>
        <div class="user-greeting">
          Halo, <span class="user-name"><%= user.username %></span>
        </div>
        <form action="/logout" method="POST" style="margin: 0;">
          <button type="submit" class="logout-btn">Logout</button>
        </form>
      <% } else { %>
        <a href="/login" style="color: white; font-size: 0.9rem; text-decoration: none; font-weight: 600;">Login Admin</a>
      <% } %>
    </div>
  </header>
  <main>